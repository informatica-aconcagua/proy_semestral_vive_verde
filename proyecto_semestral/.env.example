# Generar una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambiar-por-clave-aleatoria-segura

# True solo en desarrollo local, False en producción
DEBUG=True

# Hosts permitidos: en Vercel poner tu dominio, ej: viveverde.vercel.app,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos
# Para desarrollo local (SQLite): dejar DATABASE_URL vacío o sin definir
# Para producción (Neon PostgreSQL): pegar la URL de conexión de Neon
DATABASE_URL=

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=tu_password_de_aplicacion
EMAIL_PORT=587
